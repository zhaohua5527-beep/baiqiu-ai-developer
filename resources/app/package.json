{
  "name": "baiqiu-ai",
  "version": "1.1.15",
  "description": "Baiqiu AI desktop client with embedded OpenClaw control",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "..\\openclaw-desktop\\node_modules\\.bin\\electron.cmd .",
    "check": "node --check main.js && node --check preload.js && node --check renderer\\app.js",
    "invite": "node scripts\\generate-invite.js",
    "bundle:openclaw": "powershell -ExecutionPolicy Bypass -File scripts\\bundle-openclaw.ps1",
    "make:portable": "powershell -ExecutionPolicy Bypass -File scripts\\make-portable.ps1",
    "publish:desktop": "powershell -ExecutionPolicy Bypass -File scripts\\publish-desktop-dual.ps1",
    "pack": "electron-builder --win",
    "build:installer": "electron-builder --win nsis",
    "start:dev": "..\\openclaw-desktop\\node_modules\\.bin\\electron.cmd . --dev",
    "license:server": "node server\\license-server.js",
    "license:create": "node server\\license-server.js create",
    "publish:desktop-only": "powershell -ExecutionPolicy Bypass -File scripts\\publish-desktop-only.ps1",
    "sync:update-server": "powershell -ExecutionPolicy Bypass -File scripts\\sync-to-update-server.ps1"
  },
  "dependencies": {
    "adler-32": "^1.3.1",
    "ws": "^8.18.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "35.7.5",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.baiqiu.ai",
    "productName": "白球AI",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "zip",
        "portable"
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": false,
      "deleteAppDataOnUninstall": false,
      "shortcutName": "白球AI",
      "include": "build/installer.nsh"
    },
    "electronVersion": "35.7.5",
    "artifactName": "BaiqiuAI-Setup-${version}.${ext}"
  },
  "productName": "白球AI"
}
